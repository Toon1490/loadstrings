local function processText(raw)
	if raw:sub(1,3):lower()=="/pm" then
		local args = raw:split(" ")
		local target = findPlayer(args[2])
		if target then
			sendChat("/w "..target.Name.." "..convertText(table.concat(args," ",3)))
		end
	else
		sendChat(convertText(raw))
	end
end

