--// FILE
local allyFile = "allies.txt"

--// ALLIES
local tempAllies = {}
local savedAllies = {}

-- LOAD FILE
pcall(function()
	if readfile and isfile and isfile(allyFile) then
		for name in string.gmatch(readfile(allyFile), "[^\n]+") do
			savedAllies[name] = true
		end
	end
end)

local function saveAllies()
	if writefile then
		local str = ""
		for name,_ in pairs(savedAllies) do
			str = str .. name .. "\n"
		end
		writefile(allyFile, str)
	end
end

local function isAlly(name)
	return tempAllies[name] or savedAllies[name]
end

local function validTarget(model)
	return model.Name ~= LocalPlayer.Name and not isAlly(model.Name)
end

