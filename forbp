-- ALLY UI
local function refreshList()
	for _,v in ipairs(listFrame:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
	for _,m in ipairs(humansFolder:GetChildren()) do
		local btn = Instance.new("TextButton", listFrame)
		btn.Size = UDim2.new(1,0,0,25)
		btn.Text = (tempAllies[m.Name] and "✔ " or "")..m.Name
		btn.MouseButton1Click:Connect(function()
			tempAllies[m.Name] = not tempAllies[m.Name]
			refreshList()
		end)
	end
end

local function refreshSaved()
	for _,v in ipairs(savedFrame:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
	for name,_ in pairs(savedAllies) do
		local btn = Instance.new("TextButton", savedFrame)
		btn.Size = UDim2.new(1,0,0,25)
		btn.Text = "✔ "..name
		btn.MouseButton1Click:Connect(function()
			savedAllies[name] = nil
			saveAllies()
			refreshSaved()
		end)
	end
end

allyBtn.MouseButton1Click:Connect(function()
	listFrame.Visible = not listFrame.Visible
	saveBox.Visible = false
	addBtn.Visible = false
	savedFrame.Visible = false
	if listFrame.Visible then refreshList() end
end)

ally2Btn.MouseButton1Click:Connect(function()
	local state = not saveBox.Visible
	saveBox.Visible = state
	addBtn.Visible = state
	savedFrame.Visible = state
	listFrame.Visible = false
	if state then refreshSaved() end
end)

addBtn.MouseButton1Click:Connect(function()
	if saveBox.Text ~= "" then
		savedAllies[saveBox.Text] = true
		saveAllies()
		saveBox.Text = ""
		refreshSaved()
	end
end)

-- LOOP
RunService.RenderStepped:Connect(function()
	local myChar = LocalPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

	if looping then
		local name = textbox.Text
		local target = findTarget(name)
		if target then
			status.Text = "Status: Target Found"
			stompTarget(target)
		else
			status.Text = "Status: Not Found"
		end
	end

	if killAllLoop then
		killAll()
	end

	if crashloop then
		crashing()
	end

	crashend()

	--if crashBtn.Text == "Toggle Crash: OFF" then
		--swing:FireServer("Stomp Air","Stomp Air End")
	--end

	if myRoot then
		for _, model in ipairs(humansFolder:GetChildren()) do
			if model ~= myChar and validTarget(model) then
				local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
				if root and (root.Position - myRoot.Position).Magnitude < 10 then
					if stompFF then stompTarget(model) end
					if dropkickFF then dropkick(model) end
				end
			end
		end
	end
end)

