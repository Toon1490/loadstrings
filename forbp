-- FUNCTIONS
local function findTarget(name)
	for _, model in ipairs(humansFolder:GetChildren()) do
		if model.Name:lower() == name:lower() then
			return model
		end
		local player = Players:FindFirstChild(model.Name)
		if player and player.DisplayName:lower() == name:lower() then
			return model
		end
	end
end

local function stompTarget(model)
	if not validTarget(model) then return end
	local head = model:FindFirstChild("Head")
	if head then
		swing:FireServer("Stomp Air","Stomp Air Start")
		swing:FireServer("Stomp Air","Stomp Air Hit",head)
	end
end

local function crash(model)
	if not validTarget(model) then return end
	local head = model:FindFirstChild("Head")
	if head then
		swing:FireServer("Stomp Air","Stomp Air Start")
		swing:FireServer("Stomp Air","Stomp Air Hit")
		--swing:FireServer("Stomp Air","Stomp Air End")
	end
end


local function crashing()
	local myChar = LocalPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

	if not myRoot then return end

	for _, model in ipairs(humansFolder:GetChildren()) do
		if model ~= myChar and validTarget(model) then
			local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
			if root and (root.Position - myRoot.Position).Magnitude < 1000000 then
				crash(model)
			end
		end
	end
end


local function killAll()
	local myChar = LocalPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

	if not myRoot then return end

	for _, model in ipairs(humansFolder:GetChildren()) do
		if model ~= myChar and validTarget(model) then
			local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
			if root and (root.Position - myRoot.Position).Magnitude < 1000000 then
				stompTarget(model)
			end
		end
	end
end

local function dropkick(model)
	if not validTarget(model) then return end
	local torso = model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")
	if torso then
		swing:FireServer("Dropkick","Dropkick Start")
		swing:FireServer("Dropkick","Dropkick Hit",torso)
	end
end

local function crashend()
	if crashBtn.Text == "Toggle Crash: OFF" then
		swing:FireServer("Stomp Air","Stomp Air End")
	end
end

